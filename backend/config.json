{
  "project_name": "ICH Dance Motion Digitization System",
  "edition": "Astra RGB-D + OpenPose Edition",
  "astra": {
    "device_name": "Orbbec Astra Pro S M",
    "fps": 30,
    "rgb_width": 640,
    "rgb_height": 480,
    "depth_width": 640,
    "depth_height": 480,
    "depth_scale": 0.001
  },
  "openpose": {
    "openpose_path": "C:/openpose/bin/OpenPoseDemo.exe",
    "model": "BODY_25",
    "use_gpu": true,
    "enable_hand": false,
    "enable_face": false
  },
  "motion": {
    "default_duration_sec": 10,
    "smoothing_method": "moving_average",
    "smoothing_window": 5
  }
}
